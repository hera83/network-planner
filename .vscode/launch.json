{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Network Planner (Edge)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Network Planner",
      "program": "${workspaceFolder}/bin/Debug/net10.0/HomelabNetworkPlanner.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "microsoft-edge:%s"
      }
    }
  ]
}
